# --- Build output — regenerate via build.md, never commit ---
# (config-src/ and build.sh are source, not build output - kept out of
# the blanket ignore below via negation patterns so they're tracked)
live-build/*
!live-build/config-src/
!live-build/build.sh
*.iso

# --- Large / stale data, never commit ---
quran_audio_embedded.db
quran_audio_embedded.verses_backup.json
quran_audio.db

# --- Build artifacts ---
shell-src/build/
*.o
*.obj
moc_*
qrc_*
Makefile
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# --- Editor / OS cruft ---
*.swp
*~
.vscode/
.idea/
.DS_Store

# --- Real device data / secrets, never commit ---
*.ini

# --- Logs / IDE state ---
build.log
buildsh.log
shell-src/.qtcreator/
